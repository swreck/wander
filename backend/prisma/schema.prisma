generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  active
  archived
}

enum TransportMode {
  flight
  train
  ferry
  drive
  subway
  bus
  taxi
  shuttle
  walk
  other
}

enum LocationStatus {
  unlocated
  pending
  confirmed
}

enum ExperienceState {
  possible
  selected
  voting
}

enum Theme {
  ceramics
  architecture
  food
  temples
  nature
  other
}

enum RatingPlatform {
  google
  yelp
  foursquare
  tabelog
}

enum ReservationType {
  restaurant
  activity
  transport
  other
}

enum TravelMode {
  walk
  subway
  train
  bus
  taxi
  shuttle
  other
}

enum DocumentType {
  passport
  visa
  frequent_flyer
  insurance
  ticket
  custom
}

model Trip {
  id        String     @id @default(cuid())
  name      String
  tagline   String?
  startDate DateTime?  @map("start_date")
  endDate   DateTime?  @map("end_date")
  datesKnown Boolean   @default(true) @map("dates_known")
  anchorDate DateTime? @map("anchor_date")
  status       TripStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lastOpenedAt DateTime?  @map("last_opened_at")
  inviteToken String?  @unique @map("invite_token")

  cities            City[]
  days              Day[]
  routeSegments     RouteSegment[]
  experiences       Experience[]
  accommodations    Accommodation[]
  reservations      Reservation[]
  changeLogs        ChangeLog[]
  travelerProfiles  TravelerProfile[]
  decisions         Decision[]
  votingSessions    VotingSession[]
  chatMessages      ChatMessage[]
  experienceInterests ExperienceInterest[]
  tripMembers       TripMember[]
  tripInvites       TripInvite[]
  tripPhrases       TripPhrase[]
  learnings         Learning[]
  approvalRequests  ApprovalRequest[]
  dedupSuggestions  DedupSuggestion[]
  sheetSyncConfig   SheetSyncConfig?
  planningActions   PlanningAction[]
  sheetNotes        SheetNote[]

  @@map("trips")
}

model RouteSegment {
  id                 String        @id @default(cuid())
  tripId             String        @map("trip_id")
  originCity         String        @map("origin_city")
  destinationCity    String        @map("destination_city")
  sequenceOrder      Int           @map("sequence_order")
  transportMode      TransportMode @map("transport_mode")
  departureDate      DateTime?     @map("departure_date")
  notes              String?
  confirmationNumber String?       @map("confirmation_number")
  serviceNumber      String?       @map("service_number")
  departureTime      String?       @map("departure_time")
  arrivalTime        String?       @map("arrival_time")
  departureStation   String?       @map("departure_station")
  arrivalStation     String?       @map("arrival_station")
  seatInfo           String?       @map("seat_info")

  trip        Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  experiences Experience[]

  @@map("route_segments")
}

model City {
  id            String   @id @default(cuid())
  tripId        String   @map("trip_id")
  name          String
  tagline       String?
  country       String?
  latitude      Float?
  longitude     Float?
  sequenceOrder Int      @map("sequence_order")
  arrivalDate   DateTime? @map("arrival_date")
  departureDate DateTime? @map("departure_date")
  hidden        Boolean  @default(false)
  costEstimate  Json?    @map("cost_estimate") // { hotelDailyRate, hotelTotal, mealsDaily, budgetJA, budgetKL }

  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  days           Day[]
  experiences    Experience[]
  accommodations Accommodation[]
  decisions      Decision[]

  @@map("cities")
}

model Day {
  id              String  @id @default(cuid())
  tripId          String  @map("trip_id")
  cityId          String  @map("city_id")
  date            DateTime
  dayNumber       Int?    @map("day_number")
  dayType         String  @default("free") @map("day_type") // "free" | "guided"
  explorationZone String? @map("exploration_zone")
  notes           String?
  costEstimate    Json?   @map("cost_estimate") // { hotelJA, hotelKL, mealsJA, mealsKL, other }

  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city           City            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  experiences    Experience[]
  accommodations Accommodation[]
  reservations   Reservation[]
  personalItems  PersonalItem[]
  reflections    Reflection[]
  decisions      Decision[]

  @@map("days")
}

model Experience {
  id                          String          @id @default(cuid())
  tripId                      String          @map("trip_id")
  cityId                      String          @map("city_id")
  name                        String
  description                 String?
  sourceUrl                   String?         @map("source_url")
  sourceText                  String?         @map("source_text")
  locationStatus              LocationStatus  @default(unlocated) @map("location_status")
  latitude                    Float?
  longitude                   Float?
  placeIdGoogle               String?         @map("place_id_google")
  state                       ExperienceState @default(possible)
  dayId                       String?         @map("day_id")
  routeSegmentId              String?         @map("route_segment_id")
  timeWindow                  String?         @map("time_window")
  transportModeToHere         TravelMode?     @map("transport_mode_to_here")
  explorationZoneAssociation  String?         @map("exploration_zone_association")
  priorityOrder               Int             @default(0) @map("priority_order")
  cloudinaryImageId           String?         @map("cloudinary_image_id")
  themes                      Theme[]         @default([])
  userNotes                   String?         @map("user_notes")
  createdBy                   String          @map("created_by")
  lastEditedBy                String?         @map("last_edited_by")
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")

  culturalNotes Json?    @map("cultural_notes")
  popularTimes  Json?    @map("popular_times")
  conditionalAssignment Json? @map("conditional_assignment") // { fallbackDate, waitFor, ifInterested, ifNot }
  sheetRowRef           String? @map("sheet_row_ref") // e.g. "Activities Template:14" — null = Wander-only

  decisionId   String?           @map("decision_id")

  trip         Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city         City              @relation(fields: [cityId], references: [id], onDelete: Cascade)
  day          Day?              @relation(fields: [dayId], references: [id], onDelete: SetNull)
  routeSegment RouteSegment?     @relation(fields: [routeSegmentId], references: [id], onDelete: SetNull)
  decision     Decision?         @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  ratings      ExperienceRating[]
  interests      ExperienceInterest[]
  decisionVotes  DecisionVote[]
  reactions      ExperienceReaction[]
  notes          ExperienceNote[]

  @@map("experiences")
}

model ExperienceRating {
  id              String         @id @default(cuid())
  experienceId    String         @map("experience_id")
  platform        RatingPlatform
  ratingValue     Float          @map("rating_value")
  reviewCount     Int            @map("review_count")
  lastRefreshedAt DateTime       @default(now()) @map("last_refreshed_at")
  rawResponse     Json?          @map("raw_response")

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([experienceId, platform])
  @@map("experience_ratings")
}

model Accommodation {
  id                 String   @id @default(cuid())
  tripId             String   @map("trip_id")
  cityId             String   @map("city_id")
  dayId              String?  @map("day_id")
  name               String
  address            String?
  latitude           Float?
  longitude          Float?
  checkInTime        String?  @map("check_in_time")
  checkOutTime       String?  @map("check_out_time")
  confirmationNumber String?  @map("confirmation_number")
  notes              String?

  sheetRowRef        String?  @map("sheet_row_ref")

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city City  @relation(fields: [cityId], references: [id], onDelete: Cascade)
  day  Day?  @relation(fields: [dayId], references: [id], onDelete: SetNull)

  @@map("accommodations")
}

model Reservation {
  id                  String          @id @default(cuid())
  tripId              String          @map("trip_id")
  dayId               String          @map("day_id")
  name                String
  type                ReservationType
  datetime            DateTime
  durationMinutes     Int?            @map("duration_minutes")
  latitude            Float?
  longitude           Float?
  confirmationNumber  String?         @map("confirmation_number")
  notes               String?
  transportModeToHere TravelMode?     @map("transport_mode_to_here")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day  Day  @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

model ChangeLog {
  id              String   @id @default(cuid())
  tripId          String   @map("trip_id")
  userCode        String   @map("user_code")
  userDisplayName String   @map("user_display_name")
  actionType      String   @map("action_type")
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  entityName      String   @map("entity_name")
  description     String
  previousState   Json?    @map("previous_state")
  newState        Json?    @map("new_state")
  createdAt       DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("change_logs")
}

model TravelerProfile {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  userCode    String   @map("user_code")
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  trip      Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  documents TravelerDocument[]

  @@unique([tripId, userCode])
  @@map("traveler_profiles")
}

model TravelerDocument {
  id        String       @id @default(cuid())
  profileId String       @map("profile_id")
  type      DocumentType
  label     String?
  data      Json         @default("{}")
  isPrivate Boolean      @default(false) @map("is_private")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  profile TravelerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("traveler_documents")
}

model ExperienceInterest {
  id           String   @id @default(cuid())
  experienceId String   @map("experience_id")
  tripId       String   @map("trip_id")
  userCode     String   @map("user_code")
  displayName  String   @map("display_name")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")

  experience Experience          @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  trip       Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  reactions  InterestReaction[]

  @@unique([experienceId, userCode])
  @@map("experience_interests")
}

model InterestReaction {
  id          String   @id @default(cuid())
  interestId  String   @map("interest_id")
  userCode    String   @map("user_code")
  displayName String   @map("display_name")
  reaction    String   // "interested" | "maybe" | "pass"
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  interest ExperienceInterest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@unique([interestId, userCode])
  @@map("interest_reactions")
}


// ── Group Decisions ────────────────────────────────────────────

model Decision {
  id        String    @id @default(cuid())
  tripId    String    @map("trip_id")
  cityId    String    @map("city_id")
  dayId     String?   @map("day_id")
  title     String
  status    String    @default("open") // open | resolved
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  sheetRowRef String? @map("sheet_row_ref")

  trip    Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city    City              @relation(fields: [cityId], references: [id], onDelete: Cascade)
  day     Day?              @relation(fields: [dayId], references: [id], onDelete: SetNull)
  options Experience[]
  votes   DecisionVote[]

  @@map("decisions")
}

model DecisionVote {
  id          String   @id @default(cuid())
  decisionId  String   @map("decision_id")
  optionId    String?  @map("option_id") // null = "happy with any"
  userCode    String   @map("user_code")
  displayName String   @map("display_name")
  rank        Int      @default(1) // 1 = first choice, 2 = second, 3 = third
  createdAt   DateTime @default(now()) @map("created_at")

  decision Decision    @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  option   Experience? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([decisionId, userCode, rank])
  @@map("decision_votes")
}

model VotingSession {
  id        String    @id @default(cuid())
  tripId    String    @map("trip_id")
  question  String
  options   Json
  status    String    @default("open")
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")

  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@map("voting_sessions")
}

model Vote {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  userCode    String   @map("user_code")
  optionIndex Int      @map("option_index")
  preference  String
  createdAt   DateTime @default(now()) @map("created_at")

  session VotingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userCode, optionIndex])
  @@map("votes")
}

// ── Identity & Invitation System ───────────────────────────────

model Traveler {
  id                  String   @id @default(cuid())
  displayName         String   @unique @map("display_name")
  pinHash             String?  @map("pin_hash")
  webauthnCredentials Json?    @map("webauthn_credentials")
  webauthnChallenge   String?  @map("webauthn_challenge")
  preferences         Json?
  createdAt           DateTime @default(now()) @map("created_at")

  tripMembers         TripMember[]
  tripInvites         TripInvite[]
  learnings           Learning[]
  personalItems       PersonalItem[]
  experienceReactions ExperienceReaction[]
  experienceNotes     ExperienceNote[]
  chatMessages        ChatMessage[]
  reflections         Reflection[]
  approvalRequests    ApprovalRequest[]   @relation("ApprovalRequester")
  reviewedApprovals   ApprovalRequest[]   @relation("ApprovalReviewer")
  loginEvents         LoginEvent[]

  @@map("travelers")
}

model TripMember {
  id         String   @id @default(cuid())
  tripId     String   @map("trip_id")
  travelerId String   @map("traveler_id")
  role       String   @default("member")
  joinedAt   DateTime @default(now()) @map("joined_at")

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  traveler Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([tripId, travelerId])
  @@map("trip_members")
}

model TripPhrase {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  english   String
  romaji    String
  addedBy   String   @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("trip_phrases")
}

model TripInvite {
  id                 String    @id @default(cuid())
  tripId             String    @map("trip_id")
  expectedName       String    @map("expected_name")
  inviteToken        String?   @unique @map("invite_token")
  claimedByTravelerId String?  @map("claimed_by_traveler_id")
  claimedAt          DateTime? @map("claimed_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  claimedBy  Traveler? @relation(fields: [claimedByTravelerId], references: [id])

  @@map("trip_invites")
}

// ── Experience Reactions (iMessage-style emoji) ──────────────
model ExperienceReaction {
  id           String   @id @default(cuid())
  experienceId String   @map("experience_id")
  travelerId   String   @map("traveler_id")
  emoji        String   // "❤️" | "👍" | "🔥" | custom
  createdAt    DateTime @default(now()) @map("created_at")

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  traveler   Traveler   @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([experienceId, travelerId, emoji])
  @@map("experience_reactions")
}

// ── Experience Notes (group comments on ideas) ───────────────
model ExperienceNote {
  id           String   @id @default(cuid())
  experienceId String   @map("experience_id")
  travelerId   String   @map("traveler_id")
  content      String
  visibility   String   @default("group") // "group" | "private"
  createdAt    DateTime @default(now()) @map("created_at")

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  traveler   Traveler   @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@map("experience_notes")
}

// ── Personal Items (private per-person day reminders) ─────────
model PersonalItem {
  id         String   @id @default(cuid())
  dayId      String   @map("day_id")
  travelerId String   @map("traveler_id")
  content    String
  timeWindow String?  @map("time_window") // "morning" | "afternoon" | "evening"
  createdAt  DateTime @default(now()) @map("created_at")

  day      Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  traveler Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@map("personal_items")
}

// ── Learnings ─────────────────────────────────────────────────
model Learning {
  id           String    @id @default(cuid())
  travelerId   String    @map("traveler_id")
  tripId       String?   @map("trip_id")
  experienceId String?   @map("experience_id")
  content      String
  scope        String    @default("general") // legacy, being replaced by visibility
  visibility   String    @default("group")   // "group" | "private"
  locationTag  String?   @map("location_tag") // city or country name for surfacing
  source       String    @default("chat")    // "chat" | "activity" | "dedicated"
  createdAt    DateTime  @default(now()) @map("created_at")

  traveler   Traveler    @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  trip       Trip?       @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@map("learnings")
}

// ── Approval Requests ─────────────────────────────────────────
model ApprovalRequest {
  id            String    @id @default(cuid())
  tripId        String    @map("trip_id")
  requesterId   String    @map("requester_id")
  type          String    // "bulk_delete" | "rearrange_day" | "shift_dates" | "bulk_update"
  description   String
  payload       Json
  status        String    @default("pending") // "pending" | "approved" | "rejected"
  reviewedById  String?   @map("reviewed_by_id")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewNote    String?   @map("review_note")
  createdAt     DateTime  @default(now()) @map("created_at")

  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  requester  Traveler  @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewedBy Traveler? @relation("ApprovalReviewer", fields: [reviewedById], references: [id])

  @@map("approval_requests")
}

// ── Reflections ──────────────────────────────────────────────
model Reflection {
  id          String   @id @default(cuid())
  dayId       String   @map("day_id")
  travelerId  String   @map("traveler_id")
  highlights  String[] // experience IDs marked as highlights
  note        String?  // freeform reflection text
  mediaUrls   String[] @map("media_urls") // Cloudinary URLs
  createdAt   DateTime @default(now()) @map("created_at")

  day      Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  traveler Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([dayId, travelerId])
  @@map("reflections")
}

// ── Login Events ──────────────────────────────────────────────
model LoginEvent {
  id         String   @id @default(cuid())
  travelerId String   @map("traveler_id")
  ipAddress  String   @map("ip_address")
  userAgent  String   @map("user_agent")
  country    String?
  createdAt  DateTime @default(now()) @map("created_at")

  traveler Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@map("login_events")
}

// ── Scout Chat History ────────────────────────────────
model ChatMessage {
  id         String   @id @default(cuid())
  tripId     String   @map("trip_id")
  travelerId String   @map("traveler_id")
  role       String   // "user" | "assistant"
  content    String   @db.Text
  toolUse    Json?    @map("tool_use")
  createdAt  DateTime @default(now()) @map("created_at")

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  traveler Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@index([tripId, travelerId, createdAt])
  @@map("chat_messages")
}

// ── Sheet Notes (text from narrative tabs — Flight info, Hotel Info, meeting summaries) ─
//
// Captures every non-empty text row from tabs the structured parsers don't understand.
// The goal: Wander never silently drops anything Larisa put in the sheet, even if the rich
// content (images, merged cells) can't come through the Google Sheets API. Planners see
// the text in Wander and can click through to the source tab for the visual details.
model SheetNote {
  id         String   @id @default(cuid())
  tripId     String   @map("trip_id")
  tabName    String   @map("tab_name")    // source tab (e.g., "Flight info", "Tokyo Hotel Info")
  rowIndex   Int      @map("row_index")   // 0-based row within that tab, used for reconciliation
  text       String                       // the joined text content of that row
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt          @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, tabName, rowIndex])
  @@index([tripId, tabName])
  @@map("sheet_notes")
}

// ── Planning Actions (from Larisa's Japan Guide Actions tab) ─
model PlanningAction {
  id           String   @id @default(cuid())
  tripId       String   @map("trip_id")
  action       String
  owner        String   // "Both" | "LF" | "KR" | name
  dueDate      String?  @map("due_date") // "4/15" etc — kept as-is from Guide
  notes        String?
  status       String   @default("open") // "open" | "done"
  // Per-person statuses from Guide (Andy Status, Larisa Status, Status Notes columns).
  // Stored as raw text — Larisa's status vocabulary evolves ("DONE", "In Progress", "N/A", etc).
  andyStatus   String?  @map("andy_status")
  larisaStatus String?  @map("larisa_status")
  statusNotes  String?  @map("status_notes")
  sheetRowRef  String?  @map("sheet_row_ref")
  createdAt    DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("planning_actions")
}

// ── Spreadsheet Sync ─────────────────────────────────────────
model SheetSyncConfig {
  id             String   @id @default(cuid())
  tripId         String   @unique @map("trip_id")
  spreadsheetId  String   @map("spreadsheet_id")
  syncIntervalMs Int      @default(0) @map("sync_interval_ms") // 0 = manual only
  lastSyncAt     DateTime? @map("last_sync_at")
  lastSyncStatus String?  @map("last_sync_status") // "success" | "error" | "conflict"
  tabMappings    Json     @default("{}") @map("tab_mappings") // stores which tabs map to what
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("sheet_sync_configs")
}

model SheetSyncLog {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  direction   String   // "pull" | "push"
  status      String   // "success" | "error" | "conflict"
  summary     String   // human-readable summary
  conflicts   Json?    // array of {field, wanderValue, sheetValue, resolution}
  details     Json?    // detailed sync results
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tripId, createdAt])
  @@map("sheet_sync_logs")
}

// ── Dedup Review System ────────────────────────────────────────

model DedupSuggestion {
  id            String   @id @default(cuid())
  tripId        String   @map("trip_id")
  entityType    String   @map("entity_type")    // "accommodation", "experience", etc.
  keepId        String   @map("keep_id")        // entity to keep
  removeId      String   @map("remove_id")      // entity to remove/merge
  keepName      String   @map("keep_name")
  removeName    String   @map("remove_name")
  confidence    String   @default("high")       // "high" = auto-executed, "low" = needs planner
  autoExecuted  Boolean  @default(false) @map("auto_executed")
  status        String   @default("pending")    // "pending", "approved", "rejected", "undone"
  resolvedBy    String?  @map("resolved_by")    // userCode of planner who acted
  resolvedAt    DateTime? @map("resolved_at")
  description   String
  createdAt     DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("dedup_suggestions")
}
