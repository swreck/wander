generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  active
  archived
}

enum TransportMode {
  flight
  train
  ferry
  drive
  other
}

enum LocationStatus {
  unlocated
  pending
  confirmed
}

enum ExperienceState {
  possible
  selected
  voting
}

enum Theme {
  ceramics
  architecture
  food
  temples
  nature
  other
}

enum RatingPlatform {
  google
  yelp
  foursquare
  tabelog
}

enum ReservationType {
  restaurant
  activity
  transport
  other
}

enum TravelMode {
  walk
  subway
  train
  bus
  taxi
  shuttle
  other
}

enum DocumentType {
  passport
  visa
  frequent_flyer
  insurance
  ticket
  custom
}

model Trip {
  id        String     @id @default(cuid())
  name      String
  tagline   String?
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  status    TripStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  inviteToken String?  @unique @map("invite_token")

  cities            City[]
  days              Day[]
  routeSegments     RouteSegment[]
  experiences       Experience[]
  accommodations    Accommodation[]
  reservations      Reservation[]
  changeLogs        ChangeLog[]
  travelerProfiles  TravelerProfile[]
  decisions         Decision[]
  votingSessions    VotingSession[]
  experienceInterests ExperienceInterest[]
  tripMembers       TripMember[]
  tripInvites       TripInvite[]
  tripPhrases       TripPhrase[]

  @@map("trips")
}

model RouteSegment {
  id                 String        @id @default(cuid())
  tripId             String        @map("trip_id")
  originCity         String        @map("origin_city")
  destinationCity    String        @map("destination_city")
  sequenceOrder      Int           @map("sequence_order")
  transportMode      TransportMode @map("transport_mode")
  departureDate      DateTime?     @map("departure_date")
  notes              String?
  confirmationNumber String?       @map("confirmation_number")
  serviceNumber      String?       @map("service_number")
  departureTime      String?       @map("departure_time")
  arrivalTime        String?       @map("arrival_time")
  departureStation   String?       @map("departure_station")
  arrivalStation     String?       @map("arrival_station")
  seatInfo           String?       @map("seat_info")

  trip        Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  experiences Experience[]

  @@map("route_segments")
}

model City {
  id            String   @id @default(cuid())
  tripId        String   @map("trip_id")
  name          String
  tagline       String?
  country       String?
  latitude      Float?
  longitude     Float?
  sequenceOrder Int      @map("sequence_order")
  arrivalDate   DateTime? @map("arrival_date")
  departureDate DateTime? @map("departure_date")
  hidden        Boolean  @default(false)

  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  days           Day[]
  experiences    Experience[]
  accommodations Accommodation[]
  decisions      Decision[]

  @@map("cities")
}

model Day {
  id              String  @id @default(cuid())
  tripId          String  @map("trip_id")
  cityId          String  @map("city_id")
  date            DateTime
  explorationZone String? @map("exploration_zone")
  notes           String?

  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city           City            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  experiences    Experience[]
  accommodations Accommodation[]
  reservations   Reservation[]

  @@map("days")
}

model Experience {
  id                          String          @id @default(cuid())
  tripId                      String          @map("trip_id")
  cityId                      String          @map("city_id")
  name                        String
  description                 String?
  sourceUrl                   String?         @map("source_url")
  sourceText                  String?         @map("source_text")
  locationStatus              LocationStatus  @default(unlocated) @map("location_status")
  latitude                    Float?
  longitude                   Float?
  placeIdGoogle               String?         @map("place_id_google")
  state                       ExperienceState @default(possible)
  dayId                       String?         @map("day_id")
  routeSegmentId              String?         @map("route_segment_id")
  timeWindow                  String?         @map("time_window")
  transportModeToHere         TravelMode?     @map("transport_mode_to_here")
  explorationZoneAssociation  String?         @map("exploration_zone_association")
  priorityOrder               Int             @default(0) @map("priority_order")
  cloudinaryImageId           String?         @map("cloudinary_image_id")
  themes                      Theme[]         @default([])
  userNotes                   String?         @map("user_notes")
  createdBy                   String          @map("created_by")
  lastEditedBy                String?         @map("last_edited_by")
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")

  culturalNotes Json?    @map("cultural_notes")
  popularTimes  Json?    @map("popular_times")

  decisionId   String?           @map("decision_id")

  trip         Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city         City              @relation(fields: [cityId], references: [id], onDelete: Cascade)
  day          Day?              @relation(fields: [dayId], references: [id], onDelete: SetNull)
  routeSegment RouteSegment?     @relation(fields: [routeSegmentId], references: [id], onDelete: SetNull)
  decision     Decision?         @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  ratings      ExperienceRating[]
  interests      ExperienceInterest[]
  decisionVotes  DecisionVote[]

  @@map("experiences")
}

model ExperienceRating {
  id              String         @id @default(cuid())
  experienceId    String         @map("experience_id")
  platform        RatingPlatform
  ratingValue     Float          @map("rating_value")
  reviewCount     Int            @map("review_count")
  lastRefreshedAt DateTime       @default(now()) @map("last_refreshed_at")
  rawResponse     Json?          @map("raw_response")

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@unique([experienceId, platform])
  @@map("experience_ratings")
}

model Accommodation {
  id                 String   @id @default(cuid())
  tripId             String   @map("trip_id")
  cityId             String   @map("city_id")
  dayId              String?  @map("day_id")
  name               String
  address            String?
  latitude           Float?
  longitude          Float?
  checkInTime        String?  @map("check_in_time")
  checkOutTime       String?  @map("check_out_time")
  confirmationNumber String?  @map("confirmation_number")
  notes              String?

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city City  @relation(fields: [cityId], references: [id], onDelete: Cascade)
  day  Day?  @relation(fields: [dayId], references: [id], onDelete: SetNull)

  @@map("accommodations")
}

model Reservation {
  id                  String          @id @default(cuid())
  tripId              String          @map("trip_id")
  dayId               String          @map("day_id")
  name                String
  type                ReservationType
  datetime            DateTime
  durationMinutes     Int?            @map("duration_minutes")
  latitude            Float?
  longitude           Float?
  confirmationNumber  String?         @map("confirmation_number")
  notes               String?
  transportModeToHere TravelMode?     @map("transport_mode_to_here")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day  Day  @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

model ChangeLog {
  id              String   @id @default(cuid())
  tripId          String   @map("trip_id")
  userCode        String   @map("user_code")
  userDisplayName String   @map("user_display_name")
  actionType      String   @map("action_type")
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  entityName      String   @map("entity_name")
  description     String
  previousState   Json?    @map("previous_state")
  newState        Json?    @map("new_state")
  createdAt       DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("change_logs")
}

model TravelerProfile {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  userCode    String   @map("user_code")
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  trip      Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  documents TravelerDocument[]

  @@unique([tripId, userCode])
  @@map("traveler_profiles")
}

model TravelerDocument {
  id        String       @id @default(cuid())
  profileId String       @map("profile_id")
  type      DocumentType
  label     String?
  data      Json         @default("{}")
  isPrivate Boolean      @default(false) @map("is_private")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  profile TravelerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("traveler_documents")
}

model ExperienceInterest {
  id           String   @id @default(cuid())
  experienceId String   @map("experience_id")
  tripId       String   @map("trip_id")
  userCode     String   @map("user_code")
  displayName  String   @map("display_name")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")

  experience Experience          @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  trip       Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  reactions  InterestReaction[]

  @@unique([experienceId, userCode])
  @@map("experience_interests")
}

model InterestReaction {
  id          String   @id @default(cuid())
  interestId  String   @map("interest_id")
  userCode    String   @map("user_code")
  displayName String   @map("display_name")
  reaction    String   // "interested" | "maybe" | "pass"
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  interest ExperienceInterest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@unique([interestId, userCode])
  @@map("interest_reactions")
}


// ── Group Decisions ────────────────────────────────────────────

model Decision {
  id        String    @id @default(cuid())
  tripId    String    @map("trip_id")
  cityId    String    @map("city_id")
  title     String
  status    String    @default("open") // open | resolved
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  trip    Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city    City              @relation(fields: [cityId], references: [id], onDelete: Cascade)
  options Experience[]
  votes   DecisionVote[]

  @@map("decisions")
}

model DecisionVote {
  id          String   @id @default(cuid())
  decisionId  String   @map("decision_id")
  optionId    String?  @map("option_id") // null = "happy with any"
  userCode    String   @map("user_code")
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")

  decision Decision    @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  option   Experience? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([decisionId, userCode])
  @@map("decision_votes")
}

model VotingSession {
  id        String    @id @default(cuid())
  tripId    String    @map("trip_id")
  question  String
  options   Json
  status    String    @default("open")
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")

  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@map("voting_sessions")
}

model Vote {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  userCode    String   @map("user_code")
  optionIndex Int      @map("option_index")
  preference  String
  createdAt   DateTime @default(now()) @map("created_at")

  session VotingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userCode, optionIndex])
  @@map("votes")
}

// ── Identity & Invitation System ───────────────────────────────

model Traveler {
  id          String   @id @default(cuid())
  displayName String   @unique @map("display_name")
  pinHash     String?  @map("pin_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  tripMembers  TripMember[]
  tripInvites  TripInvite[]

  @@map("travelers")
}

model TripMember {
  id         String   @id @default(cuid())
  tripId     String   @map("trip_id")
  travelerId String   @map("traveler_id")
  role       String   @default("member")
  joinedAt   DateTime @default(now()) @map("joined_at")

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  traveler Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([tripId, travelerId])
  @@map("trip_members")
}

model TripPhrase {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  english   String
  romaji    String
  addedBy   String   @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("trip_phrases")
}

model TripInvite {
  id                 String    @id @default(cuid())
  tripId             String    @map("trip_id")
  expectedName       String    @map("expected_name")
  claimedByTravelerId String?  @map("claimed_by_traveler_id")
  claimedAt          DateTime? @map("claimed_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  claimedBy  Traveler? @relation(fields: [claimedByTravelerId], references: [id])

  @@map("trip_invites")
}
